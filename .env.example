# Cluster-wide config — same values on every host.
# Copy to .env and fill in real secrets. Each host also needs an
# env/<host>.env (see env/beam00.env etc) for per-host NODE_NAME.

# Pinned image tag. Bump deliberately.
RECKON_GATEWAY_VERSION=0.3.0

# Shared BEAM distribution cookie. Same on every cluster node.
# Generate with: openssl rand -base64 32 | tr -d '/+= '
RELEASE_COOKIE=CHANGE_ME

# Shared gossip auth secret. Same on every cluster node.
# Generate with: openssl rand -base64 32 | tr -d '/+= '
RECKON_DB_CLUSTER_SECRET=CHANGE_ME

# Gossip discovery (defaults match reckon-db's wired-in defaults).
RECKON_DB_CLUSTER_PORT=45892
RECKON_DB_CLUSTER_MULTICAST_ADDR=239.255.0.1

# gRPC service port.
RECKON_GATEWAY_PORT=50051
